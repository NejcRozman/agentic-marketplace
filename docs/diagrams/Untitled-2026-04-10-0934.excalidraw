      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892868,
      "link": null,
      "locked": false,
      "text": "\"My name is X, and I will present you CAIRN platform.\"",
      "fontSize": 44.16214921031302,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"My name is X, and I will present you CAIRN platform.\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qsTFt3k30fmIEb0ZPUKly",
      "type": "text",
      "x": 7303.076471357475,
      "y": -1748.6253010905896,
      "width": 1886.0166015625,
      "height": 110.40537302578255,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6P",
      "roundness": null,
      "seed": 791699870,
      "version": 2719,
      "versionNonce": 52404732,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892868,
      "link": null,
      "locked": false,
      "text": "\"The CAIRN platform is designed to enhance funding efficiency and democratize\nresearch in the field of AI technology.\"",
      "fontSize": 44.16214921031302,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"The CAIRN platform is designed to enhance funding efficiency and democratize research in the field of AI technology.\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "PbvoFmEAIMWJf2OO1PC0L",
      "type": "text",
