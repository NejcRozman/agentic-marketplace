    },
    {
      "id": "bbwrXgmSaz8htVrjr4pmK",
      "type": "text",
      "x": 20888.209009937425,
      "y": 3854.707251002464,
      "width": 37.8756237891896,
      "height": 18.58546168958743,
      "angle": 6.273969283173895,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
