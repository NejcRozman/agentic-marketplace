      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892870,
      "link": null,
      "locked": false,
      "text": "\"The CAIRN platform is designed to improve quality of research work, enhance funding\nefficiency and democratize research in the field of AI technology.\"",
      "fontSize": 44.16214921031302,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"The CAIRN platform is designed to improve quality of research work, enhance funding efficiency and democratize research in the field of AI technology.\"",
