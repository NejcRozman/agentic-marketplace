    },
    {
      "id": "tlYI_xHa-Mnn_W4GzmfrK",
      "type": "rectangle",
      "x": 18030.147028282576,
      "y": -7089.953012280232,
      "width": 224.39943688795933,
      "height": 114.90344627142875,
      "angle": 0,
