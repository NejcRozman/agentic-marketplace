    },
    {
      "id": "qKmamv5LxsK_SRcrHK2HM",
      "type": "text",
      "x": 14331.314289296619,
      "y": -1729.4507177496275,
      "width": 1195.1925777623935,
      "height": 148.7081975924234,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFD",
      "roundness": null,
      "seed": 1345401182,
      "version": 3434,
      "versionNonce": 1900321788,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892869,
      "link": null,
      "locked": false,
      "text": "\"In our system retroactive funding serves as a powerful\nincentive for scientists to produce impactful and reproducible\nresearch.\"",
      "fontSize": 39.65551935797957,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"In our system retroactive funding serves as a powerful incentive for scientists to produce impactful and reproducible research.\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "KJ57CzIOJL1O4K2YK46Tl",
      "type": "text",
      "x": 14333.64762262995,
      "y": -1516.304816545839,
      "width": 1195.1925777623935,
      "height": 198.27759678989787,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFE",
      "roundness": null,
      "seed": 1031360350,
      "version": 3629,
      "versionNonce": 669004228,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892869,
      "link": null,
      "locked": false,
      "text": "\"It also encourages service providers and prospective\ninvestors to support research efforts, as evidence of past\nsuccess demonstrates a researcher's ability to deliver high-\nquality results.\"",
      "fontSize": 39.65551935797957,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"It also encourages service providers and prospective investors to support research efforts, as evidence of past success demonstrates a researcher's ability to deliver high-quality results.\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
