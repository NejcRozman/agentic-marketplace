      "boundElements": [],
      "updated": 1775799892869,
      "link": null,
      "locked": false,
      "text": "Incentive mechanism",
      "fontSize": 60.36359200419418,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Incentive mechanism",
      "autoResize": false,
