    },
    {
      "id": "wE96jJk8yjdWGuYh63st_",
      "type": "text",
      "x": 12772.955832690024,
      "y": -1665.9418968881077,
      "width": 936.9094909755754,
      "height": 75.45449000524273,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
