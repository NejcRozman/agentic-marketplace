    {
      "id": "ojyvb0lO412fCo6xkmQ44",
      "type": "text",
      "x": 7325.784784345754,
      "y": -1873.2919677572565,
      "width": 1162.4832763671875,
      "height": 55.202686512891276,
      "angle": 0,
