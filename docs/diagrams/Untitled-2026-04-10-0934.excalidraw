    },
    {
      "id": "Jdc7Gx3YQ31EX1LP4tH4d",
      "type": "text",
      "x": 9891.86809733404,
      "y": -1616.7919677572565,
      "width": 2177.156123448916,
      "height": 284.1440793848982,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6L",
      "roundness": null,
      "seed": 1433755842,
      "version": 3136,
      "versionNonce": 51556604,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892868,
      "link": null,
      "locked": false,
      "text": "\"We believe that advancing AI requires funding that prioritizes research which\nis OPEN, IMPACTFUL, and REPRODUCIBLE. By meeting these criteria, we\nensure that AI research is not only more effective but also accountable and\nowned by the broader community.\"",
      "fontSize": 56.82881587697964,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"We believe that advancing AI requires funding that prioritizes research which is OPEN, IMPACTFUL, and REPRODUCIBLE. By meeting these criteria, we ensure that AI research is not only more effective but also accountable and owned by the broader community.\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "b8Nbii6M6VFOTMSQ0nAbc",
      "type": "text",
      "x": 9859.99313802414,
      "y": -575.9586344239233,
      "width": 1191.449951171875,
      "height": 165.60805953867384,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6M",
      "roundness": null,
      "seed": 847381698,
      "version": 3087,
      "versionNonce": 1902767300,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775799892868,
      "link": null,
      "locked": false,
      "text": "If all three properties are satisfied AI research will be:\n- better!\n- owned by community!",
      "fontSize": 44.16214921031302,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If all three properties are satisfied AI research will be:\n- better!\n- owned by community!",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "V0Mmb7NW2MYh8Jzr8_iV1",
